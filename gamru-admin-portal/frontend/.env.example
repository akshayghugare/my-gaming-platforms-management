# Gamru frontend env. Copy to .env for local dev.
# NOTE: every VITE_* var is baked into the build and shipped to the browser —
# do not store real secrets here.

# Backend API base URL.
#   local:  http://localhost:5000/api
#   render: https://gamru-backend.onrender.com/api
VITE_API_BASE_URL=http://localhost:5000/api

# Shared password-obfuscation secret — must match the backend's value.
VITE_PASSWORD_SECRET=hamara-engage-shared-password-secret

# Games-platform frontend origin — where the real mission games live. The
# interactive mission/tournament/bundle widgets nest a game from here and relay
# plays to GAMRU's clientAuth API. The embedding SDK can override per-page via
# data-games-base; this is the fallback for standalone / third-party embeds.
#   local:  http://localhost:5174
#   prod:   https://game-frontend-platform.netlify.app
VITE_GAMES_PLATFORM_BASE=http://localhost:5174
