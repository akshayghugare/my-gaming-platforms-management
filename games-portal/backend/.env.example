GAMRU_BACKEND_URL = http://localhost:5000/api

# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ─── PostgreSQL ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=root
DB_NAME=gamify_engage
DB_SSL=false


# ─── JWT / Auth (use >=32 random bytes in production) ────
JWT_ACCESS_SECRET=dev-access-secret-change-me-please-32+
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-32+
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Shared secret for AES-GCM password transport (must match frontend VITE_PASSWORD_SECRET)
PASSWORD_SECRET=gamify-engage-shared-password-secret

# ─── Mail (optional) ─────────────────────────────────────
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=e
MAIL_FROM=""

# Shared service-to-service secret (must match gamru's SERVICE_SHARED_KEY)
SERVICE_SHARED_KEY=hamara-gamify-shared-service-key

# Per-client API key from gamru's `clientConfig` row that represents
# this game platform. Copy from gamru admin UI: Configurations → Clients
# → "Auth Key" column. Sent as `x-client-auth-key` on every outbound call.
GAMRU_CLIENT_AUTH_KEY=
